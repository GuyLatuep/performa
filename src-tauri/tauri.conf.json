{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "performa",
  "version": "0.4.0",
  "identifier": "in.polz.performa",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "performa",
        "width": 820,
        "height": 900,
        "minWidth": 640,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/GuyLatuep/performa/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzQjYzOUQxOEYxMTM4NkIKUldSck9CR1AwVG0yRTRLR2hHMyszQkNJKzQrbi8zdHBoS0VhV21CRzlHY2JBSE5uK3l0VXZvZEEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
